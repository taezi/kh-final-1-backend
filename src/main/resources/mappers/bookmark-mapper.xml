<?xml version="1.0" encoding="utf-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.kh.mapper.BookmarkMapper">

    <insert id="addBookmark">
        insert into bookmark(userno, contentno, contenttype)
        values(#{userno},#{contentno},#{contenttype})
    </insert>

    <delete id="removeBookmark">
        delete from bookmark where contentno = #{contentno}
    </delete>

    <select id="getBookmarksByType" resultType="bookmark">
        select * from bookmark
        where contenttype = #{type} and userno = #{userno}
    </select>

    <select id="getAllBookmarks" resultType="bookmark">
        select * from bookmark
        where userno = #{userno}
    </select>


</mapper>