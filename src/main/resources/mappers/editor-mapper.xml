<?xml version="1.0" encoding="utf-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.kh.mapper.EditorMapper">

    <insert id="insertEditor">
<!--        INSERT INTO EDITOR_TABLE(editortitle, editorcontent, userno)
            VALUES (#{editortitle}, #{editorcontent}, #{userno})    -->

        INSERT INTO EDITOR_TABLE (userno, editortitle, editorcontent)
        VALUES (#{userno}, #{editortitle}, #{editorcontent})
    </insert>
    <select id="selectEditorAll">
        SELECT *
        FROM EDITOR_TABLE
        ORDER BY editorno DESC
    </select>
</mapper>