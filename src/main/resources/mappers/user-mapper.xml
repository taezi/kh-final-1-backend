<?xml version="1.0" encoding="utf-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.kh.mapper.UserMapper">

    <insert id="registerUser">
        insert into member(userid,username,password,email,nickname,role)
        values(#{userid},#{username},#{password},#{email},#{nickname},#{role})
    </insert>

    <select id="findByUserid" resultType="member">
        select * from member
        where userid = #{userid}
    </select>
    <select id="findByid" resultType="member">
        select * from member
        where userno = #{userno}
    </select>

    <select id="findByUsername" resultType="member">
        select * from member
        where username = #{beforeUsername}
    </select>

    <select id="selectAllUser" resultType="member">
        select * from member
        where role = 'user'
    </select>

    <delete id="deleteUserByUserno">
        delete from member
        where userno = #{userno}
    </delete>

    <select id="selectUserByUserno" parameterType="int" resultType="member">
        SELECT * FROM member
        WHERE userno = #{userno}
    </select>

</mapper>